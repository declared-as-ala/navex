# === Database (required) ===
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/logiflow

# === Auth (required) ===
# Generate: openssl rand -base64 32
AUTH_SECRET=replace_with_secure_random_secret
# In production set to your deployed URL (e.g. https://navex.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# === Navex (server-side only) ===
# Status/etat token — enables real COD + delivery status on scan & sync.
# Without it the app runs in simulated (mock) mode for local testing.
NAVEX_STATUS_TOKEN=
# Optional: dedicated full-parcel lookup endpoint (returns client details).
# If empty, the scan falls back to the status token above.
NAVEX_LOOKUP_ENDPOINT=
# Optional: parcel creation token (not required for scan-control workflow).
NAVEX_CREATE_TOKEN=

# Sender info used in Navex payloads
NAVEX_SENDER_NAME=LogiFlow
NAVEX_SENDER_LOCATION=Tunis
NAVEX_SENDER_GOUVERNORAT=Tunis

# === Cron (optional) ===
# Bearer secret protecting POST /api/cron/navex-sync
CRON_SECRET=replace_with_secure_secret
